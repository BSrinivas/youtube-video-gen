# YouTube Video Generator Configuration

# Pexels API Key (Get from: https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay API Key (Get from: https://pixabay.com/api/)
PIXABAY_API_KEY=your_pixabay_api_key_here

# Freesound API Key (Get from: https://freesound.org/help/developers/)
FREESOUND_API_KEY=your_freesound_api_key_here

# ElevenLabs API Key (Get from: https://elevenlabs.io/docs/api)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Google Cloud API Key (Get from: https://cloud.google.com/docs/authentication)
GOOGLE_API_KEY=your_google_api_key_here

# Project Configuration
PROJECT_OUTPUT_DIR=./output
ENABLE_LOGGING=true
LOG_LEVEL=INFO
